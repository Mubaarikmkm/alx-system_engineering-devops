#!/bin/bash

# Read the input words and sort them
input=$(cat - | tr ' ' '\n' | sort)

# Use awk to print only words that appear once
echo "$input" | awk '{
  if (!seen[$1]++) {
    count[$1] = 1;
  } else {
    count[$1]++;
  }
}
END {
  for (word in count) {
    if (count[word] == 1) {
      print word;
    }
  }
}'

